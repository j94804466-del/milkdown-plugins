{
  "name": "@xz-summer/milkdown-container",
  "version": "0.1.0",
  "description": "Container directive plugin for Milkdown - supports info, tip, warning, danger, and details containers",
  "keywords": ["milkdown", "container", "directive", "callout", "admonition"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "remark-directive": "^4.0.0"
  },
  "peerDependencies": {
    "@milkdown/kit": ">=7.0.0"
  },
  "devDependencies": {
    "@milkdown/kit": "^7.17.3",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "@xz-summer/milkdown-slash-menu-core",
  "version": "0.2.20",
  "description": "Framework-agnostic slash menu plugin for Milkdown editor | Milkdown 编辑器的框架无关斜杠菜单插件",
  "keywords": [
    "milkdown",
    "slash-menu",
    "editor",
    "plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/xiazhi926459/milkdown-plugins.git",
    "directory": "packages/slash-menu-core"
  },
  "homepage": "https://gitee.com/xiazhi926459/milkdown-plugins/tree/master/packages/slash-menu-core",
  "bugs": {
    "url": "https://gitee.com/xiazhi926459/milkdown-plugins/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@milkdown/kit": ">=7.0.0",
    "@floating-ui/dom": ">=1.0.0"
  },
  "devDependencies": {
    "@milkdown/kit": "^7.17.3",
    "@floating-ui/dom": "^1.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
